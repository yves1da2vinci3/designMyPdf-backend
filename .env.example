# Copier vers .env et remplir. Ne pas committer .env

# --- Firebase Admin (au choix) ---
# Option A : Infisical (SDK Go au démarrage — secret nommé FIREBASE_SERVICE_ACCOUNT)
INFISICAL_SITE_URL=
INFISICAL_ENVIRONMENT=dev
# Au moins un des deux :
INFISICAL_PROJECT_SLUG=
# INFISICAL_PROJECT_ID=
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=
# INFISICAL_AUTH_ORGANIZATION_SLUG=
# Alternative machine : INFISICAL_ACCESS_TOKEN=

# Option B : repli local (sans Infisical)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/chemin/vers/service-account.json

# Alias supportés par le backend : CLIENT_ID / CLIENT_SECRET (même rôle que INFISICAL_UNIVERSAL_*)
